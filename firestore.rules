rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function belongsToUser(userId) { return request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAuthority() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'AUTHORITY';
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() > 0 && data.email.size() < 256
        && data.role in ['CHW', 'AUTHORITY']
        && (!('district' in data) || data.district is string && data.district.size() < 100);
    }

    function isValidCase(data) {
      return data.patientAgeMonths is int && data.patientAgeMonths >= 0 && data.patientAgeMonths <= 216
        && data.chwId == request.auth.uid
        && data.district is string && data.district.size() > 0 && data.district.size() < 100
        && data.village is string && data.village.size() > 0 && data.village.size() < 100
        && (!('diagnosis' in data) || data.diagnosis is string && data.diagnosis.size() < 500)
        && (!('probability' in data) || data.probability is float || data.probability is int)
        && data.createdAt == request.time;
    }

    function isValidAlert(data) {
      return data.district is string && data.district.size() > 0
        && data.condition is string && data.condition.size() > 0
        && data.caseCount is int && data.caseCount >= 0
        && data.status in ['NEW', 'INVESTIGATING', 'RESOLVED']
        && data.createdAt == request.time;
    }

    // --- Rules ---

    match /users/{uid} {
      allow get: if isSignedIn();
      allow create: if isVerified() && isValidUser(incoming());
      allow update: if isVerified() && belongsToUser(uid) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['district'])
        && isValidUser(incoming());
    }

    match /cases/{caseId} {
      allow list: if isVerified() && (isAuthority() || resource.data.chwId == request.auth.uid);
      allow get: if isVerified() && (isAuthority() || resource.data.chwId == request.auth.uid);
      allow create: if isVerified() && isValidCase(incoming());
      allow update: if isVerified() && (
        (belongsToUser(existing().chwId) && incoming().diff(existing()).affectedKeys().hasOnly(['symptoms', 'hasFever', 'diagnosis', 'probability', 'malnutritionStatus', 'muacMeasurement', 'photoUrl']))
        || isAuthority()
      );
    }

    match /alerts/{alertId} {
      allow list, get: if isVerified();
      allow create: if isAuthority() && isValidAlert(incoming());
      allow update: if isAuthority() && isValidAlert(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'severity', 'caseCount']);
    }
  }
}
